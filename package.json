{
  "name": "lachesi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A GitHub-feeling Bitbucket pull request review desktop app",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "web:dev": "pnpm --filter @lachesi/web dev",
    "web:build": "pnpm --filter @lachesi/web build",
    "web:preview": "pnpm --filter @lachesi/web preview",
    "tauri": "tauri",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build --output-dir storybook-static",
    "storybook:deploy": "npx wrangler deploy --config wrangler.design-system.jsonc",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gitdiff-parser": "^0.3.1",
    "react": "^19.1.0",
    "react-diff-view": "^3.3.3",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.1",
    "recharts": "^3.8.1",
    "refractor": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.1",
    "@storybook/addon-a11y": "10.3.3",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/addon-links": "10.3.3",
    "@storybook/react-vite": "10.3.3",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^25.0.1",
    "storybook": "10.3.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.0.4",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
